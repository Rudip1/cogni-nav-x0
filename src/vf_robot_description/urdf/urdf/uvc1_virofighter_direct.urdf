<?xml version="1.0" ?>
<robot name="uvc1_virofighter" xmlns:xacro="http://ros.org/wiki/xacro">

  <!-- Init colour -->
  <material name="black">
      <color rgba="0.0 0.0 0.0 1.0"/>
  </material>

  <material name="dark">
    <color rgba="0.3 0.3 0.3 1.0"/>
  </material>

  <material name="light_black">
    <color rgba="0.4 0.4 0.4 1.0"/>
  </material>

  <material name="blue">
    <color rgba="0.0 0.0 0.8 1.0"/>
  </material>

  <material name="green">
    <color rgba="0.0 0.8 0.0 1.0"/>
  </material>

  <material name="grey">
    <color rgba="0.5 0.5 0.5 1.0"/>
  </material>

  <material name="orange">
    <color rgba="1.0 0.4235 0.0392 1.0"/>
  </material>

  <material name="brown">
    <color rgba="0.8706 0.8118 0.7647 1.0"/>
  </material>

  <material name="red">
    <color rgba="0.8 0.0 0.0 1.0"/>
  </material>

  <material name="white">
    <color rgba="1.0 1.0 1.0 1.0"/>
  </material>

  <!-- Base Footprint -->
  <link name="base_footprint"/>
  
  <joint name="base_joint" type="fixed">
    <parent link="base_footprint"/>
    <child link="base_link" />
    <!-- <origin xyz="0 0 0.010" rpy="0 0 0"/> -->
    <origin xyz="0 0 0" rpy="0 0 0"/>
  </joint>

  <!-- Base Link -->
  <link name="base_link">
    <visual name="base_visual">
      <origin xyz="-0.25 0 0.049" rpy="0 0 0"/>
      <geometry>
        <mesh filename="package://meshes/bases/virofighter_base.dae" scale="1.0 1.0 1.0"/>
      </geometry>
      <material name="white"/>
    </visual>

    <collision name="base_collision">
      <origin xyz="-0.25 0 1" rpy="0 0 0"/>
      <geometry>
        <mesh filename="package://meshes/bases/Cube.019.dae" scale="1.0 1.0 1.0"/>
      </geometry>
      <material name="white"/>
    </collision>

    <inertial>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <mass value="10.011"/>
      <inertia ixx="13.2077" ixy="0" ixz="0"
              iyy="13.3744" iyz="0"
              izz="0.34275"/>
    </inertial>
  </link>

  <!--  WHEELS -->

  <!-- wheel_front_left -->
  <joint name="wheel_front_left_joint" type="continuous">
    <parent link="base_link"/>
    <child link="wheel_front_left_link"/>
    <origin xyz="0 0.17827 0.082" rpy="0 0 0"/>
    <axis xyz="0 1.0 0"/>
    <dynamics damping="0.005" friction="0.005" />
  </joint>

  <link name="wheel_front_left_link">
    <visual name="wheel_front_left">
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <mesh filename="package://meshes/wheels/wheel_front_left.dae" scale="0.001 0.001 0.001"/>
      </geometry>
      <material name="black"/>
    </visual>

    <collision name="wheel_front_left_collision">
      <origin xyz="0 0.00277 0" rpy="1.5708 0 0"/>
      <geometry>
        <cylinder radius="0.08273" length="0.04836"/>
      </geometry>
    </collision>

    <inertial>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <mass value="7.90271"/>
      <inertia ixx="0.01506" ixy="0" ixz="0"
               iyy="0.01506" iyz="0" 
               izz="0.02704" />
    </inertial>
  </link>

  <!-- wheel_front_right -->
  <joint name="wheel_front_right_joint" type="continuous">
    <parent link="base_link"/>
    <child link="wheel_front_right_link"/>
    <origin xyz="0 -0.17827 0.082" rpy="0 0 0"/>
    <axis xyz="0 1.0 0"/>
    <dynamics damping="0.005" friction="0.005" />
  </joint>

  <link name="wheel_front_right_link">
    <visual name="wheel_front_right">
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <mesh filename="package://meshes/wheels/wheel_front_right.dae" scale="0.001 0.001 0.001"/>
      </geometry>
      <material name="black"/>
    </visual>

    <collision name="front_right_wheel_collision">
      <origin xyz="0 -0.00277 0" rpy="1.5708 0 0"/>
      <geometry>
        <cylinder radius="0.08274" length="0.04836"/>
      </geometry>
    </collision>

    <inertial>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <mass value="7.90462"/>
      <inertia ixx="0.01507" ixy="0" ixz="0"
               iyy="0.01507" iyz="0" 
               izz="0.02706" />
    </inertial>
  </link>

  <!-- wrist_rear_left_link -->
  <joint name="wrist_rear_left_joint" type="continuous">
      <parent link="base_link"/>
      <child link="wrist_rear_left_link"/>
      <origin xyz="-0.47 0.16211 0.13" rpy="0 0 0"/>
      <axis xyz="0 0 1.0"/>
      <dynamics damping="0.005" friction="0.005" />
  </joint>

  <link name="wrist_rear_left_link">
    <visual name="rear_left_wrist">
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <mesh filename="package://meshes/wheels/wrist_rear_left.dae" scale="0.001 0.001 0.001"/>
      </geometry>
      <material name="brown"/>
    </visual>

    <inertial>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <mass value="2.0"/>
      <inertia ixx="2e-05" ixy="0" ixz="0"
               iyy="2e-05" iyz="0" 
               izz="2e-05" />
    </inertial>
  </link>

  <!-- wheel_rear_left -->
  <joint name="wheel_rear_left_joint" type="continuous">
    <parent link="wrist_rear_left_link"/>
    <child link="wheel_rear_left_link"/>
    <origin xyz="0.03802 0 -0.08" rpy="0 0 0"/>
    <axis xyz="0 1.0 0"/>
    <dynamics damping="0.005" friction="0.005" />
  </joint>

  <link name="wheel_rear_left_link">
    <visual name="wheel_rear_left">
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <mesh filename="package://meshes/wheels/wheel_rear_left.dae" scale="0.001 0.001 0.001"/>
      </geometry>
      <material name="black"/>
    </visual>

    <collision name="rear_left_wheel_collision">
      <origin xyz="-3e-05 0 0" rpy="1.5708 0 0"/>
      <geometry>
        <cylinder radius="0.05072" length="0.03598"/>
      </geometry>
    </collision>

    <inertial>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <mass value="2.20995"/>
      <inertia ixx="0.00166" ixy="0" ixz="0"
               iyy="0.00166" iyz="0"
               izz="0.00284" />
    </inertial>
  </link>

  <!-- wrist_rear_right_link -->
  <joint name="wrist_rear_right_joint" type="continuous">
      <parent link="base_link"/>
      <child link="wrist_rear_right_link"/>
      <origin xyz="-0.47 -0.16211 0.13" rpy="0 0 0"/>
      <axis xyz="0 0 1.0"/>
      <dynamics damping="0.005" friction="0.005" />
  </joint>

  <link name="wrist_rear_right_link">
    <visual name="rear_right_wrist">
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <mesh filename="package://meshes/wheels/wrist_rear_right.dae" scale="0.001 0.001 0.001"/>
      </geometry>
      <material name="brown"/>
    </visual>

    <inertial>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <mass value="2.0"/>
      <inertia ixx="2e-05" ixy="0" ixz="0"
               iyy="2e-05" iyz="0" 
               izz="2e-05" />
    </inertial>
  </link>

  <!-- wheel_rear_right -->
  <joint name="wheel_rear_right_joint" type="continuous">
    <parent link="wrist_rear_right_link"/>
    <child link="wheel_rear_right_link"/>
    <origin xyz="0.03802 0 -0.08" rpy="0 0 0"/>
    <axis xyz="0 1.0 0"/>
    <dynamics damping="0.005" friction="0.005" />
  </joint>

  <link name="wheel_rear_right_link">
    <visual name="wheel_rear_right">
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <mesh filename="package://meshes/wheels/wheel_rear_right.dae" scale="0.001 0.001 0.001"/>
      </geometry>
      <material name="black"/>
    </visual>

    <collision name="rear_right_wheel_collision">
      <origin xyz="-3e-05 0 0" rpy="1.5708 0 0"/>
      <geometry>
        <cylinder radius="0.05072" length="0.03598"/>
      </geometry>
    </collision>

    <inertial>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <mass value="2.20995"/>
      <inertia ixx="0.00166" ixy="0" ixz="0"
               iyy="0.00166" iyz="0"
               izz="0.00284" />
    </inertial>
  </link>

  <!--  SENSORS -->

  <!-- ============================= -->
  <!-- 1. Camera D455 RealSense (on Base) -->
  <!-- ============================= -->

  <!-- Fixed joint to base -->
  <joint name="camera_d455_joint" type="fixed">
    <parent link="base_link"/>
    <child link="camera_d455_link"/>
    <origin xyz="-0.52457 0 0.42892" rpy="0 0 3.1416"/>
  </joint>

  <!-- Camera main link -->
  <link name="camera_d455_link">
    <visual name="d455_visual">
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <box size="0.029 0.124 0.025"/>
      </geometry>
    </visual>

    <collision name="camera_d455_collision">
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <box size="0.029 0.124 0.025"/>
      </geometry>
    </collision>

    <inertial>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <mass value="0.159"/>
      <inertia ixx="1.2e-05" ixy="0" ixz="0"
              iyy="2.1e-04" iyz="0"
              izz="2.2e-04"/>
    </inertial>
  </link>

  <!-- RGB Optical Frame -->
  <link name="camera_d455_color_optical_frame"/>
  <joint name="camera_d455_color_optical_joint" type="fixed">
    <parent link="camera_d455_link"/>
    <child link="camera_d455_color_optical_frame"/>
    <origin xyz="0 0 0" rpy="-1.5708 0 -1.5708"/>
  </joint>

  <!-- Depth Optical Frame -->
  <link name="camera_d455_depth_optical_frame"/>
  <joint name="camera_d455_depth_optical_joint" type="fixed">
    <parent link="camera_d455_link"/>
    <child link="camera_d455_depth_optical_frame"/>
    <origin xyz="0 0 0" rpy="-1.5708 0 -1.5708"/>
  </joint>

  <!-- IMU Frame -->
  <link name="camera_d455_imu_frame"/>
  <joint name="camera_d455_imu_joint" type="fixed">
    <parent link="camera_d455_link"/>
    <child link="camera_d455_imu_frame"/>
    <origin xyz="0 0 0" rpy="0 0 0"/>
  </joint>

  <!-- ============================= -->
  <!-- 2. Camera D435i RealSense (on Top) -->
  <!-- ============================= -->
  <!-- Fixed joint to base -->
  <joint name="camera_d435i_joint" type="fixed">
    <parent link="base_link"/>
    <child link="camera_d435i_link"/>
    <origin xyz="0.04512 0 1.77259" rpy="0 1.0472 0"/>
  </joint>

  <!-- Camera main link -->
  <link name="camera_d435i_link">
    <visual name="d435i_visual">
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <mesh filename="package://meshes/sensors/camera_d435i.dae" scale="0.001 0.001 0.001"/>
      </geometry>
    </visual>

    <collision name="d435i_collision">
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <box size="0.09 0.025 0.025"/>
      </geometry>
    </collision>

    <inertial>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <mass value="0.072"/>
      <inertia ixx="6.25e-05" ixy="0" ixz="0"
              iyy="7.0e-05" iyz="0"
              izz="7.0e-05"/>
    </inertial>
  </link>

  <!-- Camera D435i RGB Optical Frame -->
  <link name="camera_d435i_color_optical_frame"/>
  <joint name="camera_d435i_color_optical_joint" type="fixed">
    <parent link="camera_d435i_link"/>
    <child link="camera_d435i_color_optical_frame"/>
    <origin xyz="0 0 0" rpy="-1.5708 0 -1.5708"/> <!-- rotate to optical frame -->
  </joint>

  <!-- Camera D435i Depth Optical Frame -->
  <link name="camera_d435i_depth_optical_frame"/>
  <joint name="camera_d435i_depth_optical_joint" type="fixed">
    <parent link="camera_d435i_link"/>
    <child link="camera_d435i_depth_optical_frame"/>
    <origin xyz="0 0 0" rpy="-1.5708 0 -1.5708"/> <!-- rotate to optical frame -->
  </joint>

  <!-- Camera D435i IMU Frame -->
  <link name="camera_d435i_imu_frame"/>
  <joint name="camera_d435i_imu_joint" type="fixed">
    <parent link="camera_d435i_link"/>
    <child link="camera_d435i_imu_frame"/>
    <origin xyz="0 0 0" rpy="0 0 0"/> <!-- IMU aligned with camera link -->
  </joint>

 
  <!-- ============================= -->
  <!-- 3. Cameras Fisheyes (4 on Top) -->
  <!-- ============================= -->

  <!-- Camera Fisheye Front -->
  <joint name="camera_fisheye_front_joint" type="fixed">
    <parent link="base_link"/>
    <child link="camera_fisheye_front_link"/>
    <origin xyz="0.07 0 1.845" rpy="0 0.628 -0.0255"/>
  </joint>

  <link name="camera_fisheye_front_link">
    <visual name="fisheye_front">
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <sphere radius="0.00346"/>
      </geometry>
    </visual>

    <inertial>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <mass value="0.01"/>
      <inertia ixx="1e-06" ixy="0" ixz="0" 
               iyy="1e-06" iyz="0" 
               izz="1e-06" />
    </inertial>
  </link>

  <!-- Camera Fisheye Front Optical Frame -->
  <link name="camera_fisheye_front_optical_frame"/>
  <joint name="camera_fisheye_front_optical_joint" type="fixed">
    <parent link="camera_fisheye_front_link"/>
    <child link="camera_fisheye_front_optical_frame"/>
    <origin xyz="0 0 0" rpy="-1.5708 0 -1.5708"/> <!-- rotate to optical frame -->
  </joint>

  <!--Camera Fisheye Left-->
  <joint name="camera_fisheye_left_joint" type="fixed">
      <origin xyz="-0.2 0.18 1.845" rpy="0 0.628 1.5708"/>
      <parent link="base_link"/>
      <child link="camera_fisheye_left_link"/>
  </joint>

  <link name="camera_fisheye_left_link">
    <visual name="fisheye_left">
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
         <sphere radius="0.00346"/>
      </geometry>
    </visual>

    <inertial>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <mass value="0.01"/>
      <inertia ixx="1e-06" ixy="0" ixz="0" 
               iyy="1e-06" iyz="0" 
               izz="1e-06" />
    </inertial>
  </link>

  <!-- Camera Fisheye Left Optical Frame -->
  <link name="camera_fisheye_left_optical_frame"/>
  <joint name="camera_fisheye_left_optical_joint" type="fixed">
    <parent link="camera_fisheye_left_link"/>
    <child link="camera_fisheye_left_optical_frame"/>
    <origin xyz="0 0 0" rpy="-1.5708 0 -1.5708"/> <!-- rotate to optical frame -->
  </joint>

  <!-- Camera Fisheye Right -->
  <joint name="camera_fisheye_right_joint" type="fixed">
      <origin xyz="-0.2 -0.18 1.845" rpy="0 0.628 -1.5708"/>
      <parent link="base_link"/>
      <child link="camera_fisheye_right_link"/>
  </joint>

  <link name="camera_fisheye_right_link">
    <visual name="fisheye_right">
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <sphere radius="0.00346"/>
      </geometry>
    </visual>

    <inertial>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <mass value="0.01"/>
      <inertia ixx="1e-06" ixy="0" ixz="0" 
               iyy="1e-06" iyz="0" 
               izz="1e-06" />
    </inertial>
  </link>

  <!-- Camera Fisheye Right Optical Frame -->
  <link name="camera_fisheye_right_optical_frame"/>
  <joint name="camera_fisheye_right_optical_joint" type="fixed">
    <parent link="camera_fisheye_right_link"/>
    <child link="camera_fisheye_right_optical_frame"/>
    <origin xyz="0 0 0" rpy="-1.5708 0 -1.5708"/> <!-- rotate to optical frame -->
  </joint>

  <!-- Camera Fisheye Rear -->
  <joint name="camera_fisheye_rear_joint" type="fixed">
    <parent link="base_link"/>
    <child link="camera_fisheye_rear_link"/>
    <origin xyz="-0.5 0 1.845" rpy="3.1416 2.513274 0"/>
  </joint>

  <link name="camera_fisheye_rear_link">
    <visual name="fisheye_rear">
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <sphere radius="0.00346"/>
      </geometry>
    </visual>

    <inertial>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <mass value="0.01"/>
      <inertia ixx="1e-06" ixy="0" ixz="0" 
               iyy="1e-06" iyz="0" 
               izz="1e-06" />
    </inertial>
  </link>

  <!-- Camera Fisheye Rear Optical Frame -->
  <link name="camera_fisheye_rear_optical_frame"/>
  <joint name="camera_fisheye_rear_optical_joint" type="fixed">
    <parent link="camera_fisheye_rear_link"/>
    <child link="camera_fisheye_rear_optical_frame"/>
    <origin xyz="0 0 0" rpy="-1.5708 0 -1.5708"/> <!-- rotate to optical frame -->
  </joint>
  
  <!-- ============================= -->
  <!-- 4. Ultrasonic Sensors (5 on Base)-->
  <!-- ============================= -->
  
  <!-- Ultrasonic Front Left  -->
    <joint name="ultrasonic_front_left_joint" type="fixed">
    <origin xyz="0.08 -0.1293 0.2115" rpy="0 0 0"/>
    <parent link="base_link"/>
    <child link="ultrasonic_front_left_link"/>
  </joint>

  <link name="ultrasonic_front_left_link">
    <visual name="front_left_sonar">
      <origin xyz="0 0 0" rpy="0 0 0"/> <!-- no rotation -->
      <geometry>
        <sphere radius="0.00346"/>
      </geometry>
    </visual>

    <inertial>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <mass value="0.01"/>
      <inertia ixx="1e-06" ixy="0" ixz="0" 
              iyy="1e-06" iyz="0" 
              izz="1e-06" />
    </inertial>
  </link>

  <!-- Ultrasonic Front Right -->
  <joint name="ultrasonic_front_right_joint" type="fixed">
    <origin xyz="0.08 0.1337 0.21166" rpy="0 0 0"/>
    <parent link="base_link"/>
    <child link="ultrasonic_front_right_link"/>
  </joint>

  <link name="ultrasonic_front_right_link">
    <visual name="front_right_sonar">
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <sphere radius="0.00346"/>
      </geometry>
    </visual>

    <inertial>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <mass value="0.01"/>
      <inertia ixx="1e-06" ixy="0" ixz="0" 
               iyy="1e-06" iyz="0" 
               izz="1e-06" />
    </inertial>
  </link>

  <!-- Ultrasonic Side Left -->
  <joint name="ultrasonic_side_left_joint" type="fixed">
    <parent link="base_link"/>
    <child link="ultrasonic_side_left_link"/>
    <origin xyz="-0.34701 -0.215 0.21154" rpy="0 0 -1.5708"/>
  </joint>

  <link name="ultrasonic_side_left_link">
    <visual name="side_left_sonar">
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <sphere radius="0.00346"/>
      </geometry>
    </visual>

    <inertial>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <mass value="0.01"/>
      <inertia ixx="1e-06" ixy="0" ixz="0" 
               iyy="1e-06" iyz="0" 
               izz="1e-06" />
    </inertial>
  </link>

  <!-- Ultrasonic Side Right -->
  <joint name="ultrasonic_side_right_joint" type="fixed">
    <origin xyz="-0.34701 0.215 0.21154" rpy="0 0 1.5708"/>
    <parent link="base_link"/>
    <child link="ultrasonic_side_right_link"/>
  </joint>

  <link name="ultrasonic_side_right_link">
    <visual name="side_right_sonar">
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <sphere radius="0.00346"/>
      </geometry>
    </visual>

    <inertial>
        <origin xyz="0 0 0" rpy="0 0 0"/>
        <mass value="0.01"/>
        <inertia ixx="1e-06" ixy="0" ixz="0" 
                 iyy="1e-06" iyz="0" 
                 izz="1e-06" />
     </inertial>
    </link>

  <!-- Ultrasonic Rear  -->
  <joint name="ultrasonic_rear_joint" type="fixed">
      <origin xyz="-0.562 0.01302 0.33103" rpy="0 0 3.14159"/>
      <parent link="base_link"/>
      <child link="ultrasonic_rear_link"/>
  </joint>

  <link name="ultrasonic_rear_link">
    <visual name="rear_sonar">
        <origin xyz="0 0 0" rpy="0 0 0"/>
        <geometry>
          <sphere radius="0.00346"/>
        </geometry>
    </visual>

    <inertial>
        <origin xyz="0 0 0" rpy="0 0 0"/>
        <mass value="0.01"/>
        <inertia ixx="1e-06" ixy="0" ixz="0" 
                 iyy="1e-06" iyz="0" 
                 izz="1e-06" />
    </inertial>
  </link>

  <!-- ============================= -->
  <!--UVC Lights (6 on Base)-->
  <!-- ============================= -->

  <joint name="uvc_lights_joint" type="fixed">
    <parent link="base_link"/>
    <child link="uvc_lights_link"/>
    <origin xyz="-0.3361 0 0.52606" rpy="0 0 0"/>
  </joint>

  <link name="uvc_lights_link">
    <visual name="light_1">
      <origin xyz="-0.10432 -0.07221 0.64035" rpy="0 0 0"/>
      <geometry>
        <cylinder radius="0.01004" length="1.32715"/>
      </geometry>
      <material name="blue"/>
    </visual>

    <visual name="light_2">
      <origin xyz="-0.10432 0.07284 0.64035" rpy="0 0 0"/>
      <geometry>
        <cylinder radius="0.01004" length="1.32715"/>
