<?xml version="1.0" ?>
<robot name="uvc1_virofighter" xmlns:xacro="http://ros.org/wiki/xacro">

  <!-- Init colour -->
  <material name="black">
      <color rgba="0.0 0.0 0.0 1.0"/>
  </material>

  <material name="dark">
    <color rgba="0.3 0.3 0.3 1.0"/>
  </material>

  <material name="light_black">
    <color rgba="0.4 0.4 0.4 1.0"/>
  </material>

  <material name="blue">
    <color rgba="0.0 0.0 0.8 1.0"/>
  </material>

  <material name="green">
    <color rgba="0.0 0.8 0.0 1.0"/>
  </material>

  <material name="grey">
    <color rgba="0.5 0.5 0.5 1.0"/>
  </material>

  <material name="orange">
    <color rgba="1.0 0.4235 0.0392 1.0"/>
  </material>

  <material name="brown">
    <color rgba="0.8706 0.8118 0.7647 1.0"/>
  </material>

  <material name="red">
    <color rgba="0.8 0.0 0.0 1.0"/>
  </material>

  <material name="white">
    <color rgba="1.0 1.0 1.0 1.0"/>
  </material>

  <!-- Base Footprint -->
  <link name="base_footprint"/>
  
  <joint name="base_joint" type="fixed">
    <parent link="base_footprint"/>
    <child link="base_link" />
    <!-- <origin xyz="0 0 0.010" rpy="0 0 0"/> -->
    <origin xyz="0 0 0" rpy="0 0 0"/>
  </joint>

  <!-- Base Link -->
  <link name="base_link">
    <visual name="base_visual">
      <origin xyz="-0.25 0 0.049" rpy="0 0 0"/>
      <geometry>
        <mesh filename="package://vf_robot_description/meshes/bases/virofighter_base.dae" scale="1.0 1.0 1.0"/>
      </geometry>
      <material name="white"/>
    </visual>

    <collision name="base_collision">
      <origin xyz="-0.25 0 1" rpy="0 0 0"/>
      <geometry>
        <mesh filename="package://vf_robot_description/meshes/bases/Cube.019.dae" scale="1.0 1.0 1.0"/>
      </geometry>
      <material name="white"/>
    </collision>

    <inertial>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <mass value="10.011"/>
      <inertia ixx="13.2077" ixy="0" ixz="0"
              iyy="13.3744" iyz="0"
              izz="0.34275"/>
    </inertial>
  </link>

  <!--  WHEELS -->

  <!-- wheel_front_left -->
  <joint name="wheel_front_left_joint" type="continuous">
    <parent link="base_link"/>
    <child link="wheel_front_left_link"/>
    <origin xyz="0 0.17827 0.082" rpy="0 0 0"/>
    <axis xyz="0 1.0 0"/>
    <dynamics damping="0.005" friction="0.005" />
  </joint>

  <link name="wheel_front_left_link">
    <visual name="wheel_front_left">
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <mesh filename="package://vf_robot_description/meshes/wheels/wheel_front_left.dae" scale="0.001 0.001 0.001"/>
      </geometry>
      <material name="black"/>
    </visual>

    <collision name="wheel_front_left_collision">
      <origin xyz="0 0.00277 0" rpy="1.5708 0 0"/>
      <geometry>
        <cylinder radius="0.08273" length="0.04836"/>
      </geometry>
    </collision>

    <inertial>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <mass value="7.90271"/>
      <inertia ixx="0.01506" ixy="0" ixz="0"
               iyy="0.01506" iyz="0" 
               izz="0.02704" />
    </inertial>
  </link>

  <!-- wheel_front_right -->
  <joint name="wheel_front_right_joint" type="continuous">
    <parent link="base_link"/>
    <child link="wheel_front_right_link"/>
    <origin xyz="0 -0.17827 0.082" rpy="0 0 0"/>
    <axis xyz="0 1.0 0"/>
    <dynamics damping="0.005" friction="0.005" />
  </joint>

  <link name="wheel_front_right_link">
    <visual name="wheel_front_right">
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <mesh filename="package://vf_robot_description/meshes/wheels/wheel_front_right.dae" scale="0.001 0.001 0.001"/>
      </geometry>
      <material name="black"/>
    </visual>

    <collision name="front_right_wheel_collision">
      <origin xyz="0 -0.00277 0" rpy="1.5708 0 0"/>
      <geometry>
        <cylinder radius="0.08274" length="0.04836"/>
      </geometry>
    </collision>

    <inertial>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <mass value="7.90462"/>
      <inertia ixx="0.01507" ixy="0" ixz="0"
               iyy="0.01507" iyz="0" 
               izz="0.02706" />
    </inertial>
  </link>

  <!-- wrist_rear_left_link -->
  <joint name="wrist_rear_left_joint" type="continuous">
      <parent link="base_link"/>
      <child link="wrist_rear_left_link"/>
      <origin xyz="-0.47 0.16211 0.13" rpy="0 0 0"/>
      <axis xyz="0 0 1.0"/>
      <dynamics damping="0.005" friction="0.005" />
  </joint>

  <link name="wrist_rear_left_link">
    <visual name="rear_left_wrist">
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <mesh filename="package://vf_robot_description/meshes/wheels/wrist_rear_left.dae" scale="0.001 0.001 0.001"/>
      </geometry>
      <material name="brown"/>
    </visual>

    <inertial>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <mass value="2.0"/>
      <inertia ixx="2e-05" ixy="0" ixz="0"
               iyy="2e-05" iyz="0" 
               izz="2e-05" />
    </inertial>
  </link>

  <!-- wheel_rear_left -->
  <joint name="wheel_rear_left_joint" type="continuous">
    <parent link="wrist_rear_left_link"/>
    <child link="wheel_rear_left_link"/>
    <origin xyz="0.03802 0 -0.08" rpy="0 0 0"/>
    <axis xyz="0 1.0 0"/>
    <dynamics damping="0.005" friction="0.005" />
  </joint>

  <link name="wheel_rear_left_link">
    <visual name="wheel_rear_left">
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <mesh filename="package://vf_robot_description/meshes/wheels/wheel_rear_left.dae" scale="0.001 0.001 0.001"/>
      </geometry>
      <material name="black"/>
    </visual>

    <collision name="rear_left_wheel_collision">
      <origin xyz="-3e-05 0 0" rpy="1.5708 0 0"/>
      <geometry>
        <cylinder radius="0.05072" length="0.03598"/>
      </geometry>
    </collision>

    <inertial>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <mass value="2.20995"/>
      <inertia ixx="0.00166" ixy="0" ixz="0"
               iyy="0.00166" iyz="0"
               izz="0.00284" />
    </inertial>
  </link>

  <!-- wrist_rear_right_link -->
  <joint name="wrist_rear_right_joint" type="continuous">
      <parent link="base_link"/>
      <child link="wrist_rear_right_link"/>
      <origin xyz="-0.47 -0.16211 0.13" rpy="0 0 0"/>
      <axis xyz="0 0 1.0"/>
      <dynamics damping="0.005" friction="0.005" />
  </joint>

  <link name="wrist_rear_right_link">
    <visual name="rear_right_wrist">
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <mesh filename="package://vf_robot_description/meshes/wheels/wrist_rear_right.dae" scale="0.001 0.001 0.001"/>
      </geometry>
      <material name="brown"/>
    </visual>

    <inertial>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <mass value="2.0"/>
      <inertia ixx="2e-05" ixy="0" ixz="0"
               iyy="2e-05" iyz="0" 
               izz="2e-05" />
    </inertial>
  </link>

  <!-- wheel_rear_right -->
  <joint name="wheel_rear_right_joint" type="continuous">
    <parent link="wrist_rear_right_link"/>
    <child link="wheel_rear_right_link"/>
    <origin xyz="0.03802 0 -0.08" rpy="0 0 0"/>
    <axis xyz="0 1.0 0"/>
    <dynamics damping="0.005" friction="0.005" />
  </joint>

  <link name="wheel_rear_right_link">
    <visual name="wheel_rear_right">
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <mesh filename="package://vf_robot_description/meshes/wheels/wheel_rear_right.dae" scale="0.001 0.001 0.001"/>
      </geometry>
      <material name="black"/>
    </visual>

    <collision name="rear_right_wheel_collision">
      <origin xyz="-3e-05 0 0" rpy="1.5708 0 0"/>
      <geometry>
        <cylinder radius="0.05072" length="0.03598"/>
      </geometry>
    </collision>

    <inertial>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <mass value="2.20995"/>
      <inertia ixx="0.00166" ixy="0" ixz="0"
               iyy="0.00166" iyz="0"
               izz="0.00284" />
    </inertial>
  </link>

  <!--  SENSORS -->

  <!-- ============================= -->
  <!-- 1. Camera D455 RealSense (on Base) -->
  <!-- ============================= -->

  <!-- Fixed joint to base -->
  <joint name="camera_d455_joint" type="fixed">
    <parent link="base_link"/>
    <child link="camera_d455_link"/>
    <origin xyz="-0.52457 0 0.42892" rpy="0 0 3.1416"/>
  </joint>

  <!-- Camera main link -->
  <link name="camera_d455_link">
    <visual name="d455_visual">
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <box size="0.029 0.124 0.025"/>
      </geometry>
    </visual>

    <collision name="camera_d455_collision">
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <box size="0.029 0.124 0.025"/>
      </geometry>
    </collision>

    <inertial>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <mass value="0.159"/>
      <inertia ixx="1.2e-05" ixy="0" ixz="0"
              iyy="2.1e-04" iyz="0"
              izz="2.2e-04"/>
    </inertial>
  </link>

  <!-- RGB Optical Frame -->
  <link name="camera_d455_color_optical_frame"/>
  <joint name="camera_d455_color_optical_joint" type="fixed">
    <parent link="camera_d455_link"/>
    <child link="camera_d455_color_optical_frame"/>
    <origin xyz="0 0 0" rpy="-1.5708 0 -1.5708"/>
  </joint>

  <!-- Depth Optical Frame -->
  <link name="camera_d455_depth_optical_frame"/>
  <joint name="camera_d455_depth_optical_joint" type="fixed">
    <parent link="camera_d455_link"/>
    <child link="camera_d455_depth_optical_frame"/>
    <origin xyz="0 0 0" rpy="-1.5708 0 -1.5708"/>
  </joint>

  <!-- IMU Frame -->
  <link name="camera_d455_imu_frame"/>
  <joint name="camera_d455_imu_joint" type="fixed">
    <parent link="camera_d455_link"/>
    <child link="camera_d455_imu_frame"/>
    <origin xyz="0 0 0" rpy="0 0 0"/>
  </joint>

  <!-- ============================= -->
  <!-- Gazebo plugins for Camera D455 RealSense -->
  <!-- ============================= -->
  <gazebo reference="camera_d455_link">

    <!-- RGB Camera -->
    <sensor name="d455_rgb" type="camera">
      <pose>0 0 0 0 0 0</pose>
      <always_on>true</always_on>
      <visualize>true</visualize>
      <update_rate>30</update_rate>

      <camera>
        <horizontal_fov>1.5</horizontal_fov>
        <image>
          <width>1280</width>
          <height>800</height>
          <format>R8G8B8</format>
        </image>
        <clip>
          <near>0.05</near>
          <far>20.0</far>
        </clip>
      </camera>

      <plugin name="d455_rgb_camera_controller" filename="libgazebo_ros_camera.so">
        <ros>
          <namespace>/d455/rgb</namespace>
        </ros>
        <frame_name>camera_d455_color_optical_frame</frame_name>
        <image_topic_name>/d455/color/image_raw</image_topic_name>
        <camera_info_topic_name>/d455/color/camera_info</camera_info_topic_name>
      </plugin>
    </sensor>

    <!-- Depth Camera -->
      <sensor name="d455_depth" type="depth">
        <pose>0 0 0 0 0 0</pose>
        <always_on>true</always_on>
        <visualize>true</visualize>
        <update_rate>30</update_rate>

        <camera>
          <horizontal_fov>1.52</horizontal_fov>
          <image>
            <width>1280</width>
            <height>720</height>
          </image>
          <clip>
            <near>0.6</near>
            <far>6.0</far>
          </clip>
        </camera>

        <plugin name="d455_depth_camera_controller" filename="libgazebo_ros_camera.so">
          <ros>
            <namespace>/d455/depth</namespace>
          </ros>
          <frame_name>camera_d455_depth_optical_frame</frame_name>
          <depth_image_topic_name>image_raw</depth_image_topic_name>
          <point_cloud_topic_name>points</point_cloud_topic_name>
          <depth_image_camera_info_topic_name>camera_info</depth_image_camera_info_topic_name>
          <point_cloud>true</point_cloud>
        </plugin>
      </sensor>

    <!-- IMU -->
    <sensor name="d455_imu" type="imu">
      <always_on>true</always_on>
      <update_rate>200</update_rate>

      <plugin name="d455_imu_controller" filename="libgazebo_ros_imu_sensor.so">
        <ros>
          <namespace>/d455/imu</namespace>
        </ros>
        <frame_name>camera_d455_imu_frame</frame_name>
        <topic_name>/d455/imu/data_raw</topic_name>
        <gaussian_noise>0.0005</gaussian_noise>
      </plugin>
    </sensor>

  </gazebo>

  <!-- ============================= -->
  <!-- 2. Camera D435i RealSense (on Top) -->
  <!-- ============================= -->
  <!-- Fixed joint to base -->
  <joint name="camera_d435i_joint" type="fixed">
    <parent link="base_link"/>
    <child link="camera_d435i_link"/>
    <origin xyz="0.04512 0 1.77259" rpy="0 1.0472 0"/>
  </joint>

  <!-- Camera main link -->
  <link name="camera_d435i_link">
    <visual name="d435i_visual">
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <mesh filename="package://vf_robot_description/meshes/sensors/camera_d435i.dae" scale="0.001 0.001 0.001"/>
      </geometry>
    </visual>

    <collision name="d435i_collision">
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <box size="0.09 0.025 0.025"/>
      </geometry>
    </collision>

    <inertial>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <mass value="0.072"/>
      <inertia ixx="6.25e-05" ixy="0" ixz="0"
              iyy="7.0e-05" iyz="0"
              izz="7.0e-05"/>
    </inertial>
  </link>

  <!-- Camera D435i RGB Optical Frame -->
  <link name="camera_d435i_color_optical_frame"/>
  <joint name="camera_d435i_color_optical_joint" type="fixed">
    <parent link="camera_d435i_link"/>
    <child link="camera_d435i_color_optical_frame"/>
    <origin xyz="0 0 0" rpy="-1.5708 0 -1.5708"/> <!-- rotate to optical frame -->
  </joint>

  <!-- Camera D435i Depth Optical Frame -->
  <link name="camera_d435i_depth_optical_frame"/>
  <joint name="camera_d435i_depth_optical_joint" type="fixed">
    <parent link="camera_d435i_link"/>
    <child link="camera_d435i_depth_optical_frame"/>
    <origin xyz="0 0 0" rpy="-1.5708 0 -1.5708"/> <!-- rotate to optical frame -->
  </joint>

  <!-- Camera D435i IMU Frame -->
  <link name="camera_d435i_imu_frame"/>
  <joint name="camera_d435i_imu_joint" type="fixed">
    <parent link="camera_d435i_link"/>
    <child link="camera_d435i_imu_frame"/>
    <origin xyz="0 0 0" rpy="0 0 0"/> <!-- IMU aligned with camera link -->
  </joint>

  <!-- ============================= -->
  <!-- Gazebo plugins for Camera D435i RealSense -->
  <!-- ============================= -->
  <gazebo reference="camera_d435i_link">

    <!-- RGB Camera -->
    <sensor name="d435i_rgb" type="camera">
      <pose>0 0 0 0 0 0</pose>
      <always_on>true</always_on>
      <visualize>true</visualize>
      <update_rate>30</update_rate>

      <camera>
        <horizontal_fov>1.5</horizontal_fov>
        <image>
          <width>1280</width>
          <height>800</height>
          <format>R8G8B8</format>
        </image>
        <clip>
          <near>0.05</near>
          <far>20.0</far>
        </clip>
      </camera>

      <plugin name="d435i_rgb_camera_controller" filename="libgazebo_ros_camera.so">
        <ros>
          <namespace>/d435i/rgb</namespace>
        </ros>
        <frame_name>camera_d435i_color_optical_frame</frame_name>
        <image_topic_name>/d435i/color/image_raw</image_topic_name>
        <camera_info_topic_name>/d435i/color/camera_info</camera_info_topic_name>
      </plugin>
    </sensor>

    <!-- Depth Camera -->
    <sensor name="d435i_depth" type="depth">
      <pose>0 0 0 0 0 0</pose>
      <always_on>true</always_on>
      <visualize>true</visualize>
      <update_rate>30</update_rate>

      <camera>
        <horizontal_fov>1.52</horizontal_fov>
        <image>
          <width>1280</width>
          <height>720</height>
        </image>
        <clip>
          <near>0.6</near>
          <far>6.0</far>
        </clip>
      </camera>

      <plugin name="d435i_depth_camera_controller" filename="libgazebo_ros_camera.so">
        <ros>
          <namespace>/d435i/depth</namespace>
        </ros>
        <frame_name>camera_d435i_depth_optical_frame</frame_name>
        <depth_image_topic_name>image_raw</depth_image_topic_name>
        <point_cloud_topic_name>points</point_cloud_topic_name>
        <depth_image_camera_info_topic_name>camera_info</depth_image_camera_info_topic_name>
        <point_cloud>true</point_cloud>
      </plugin>
    </sensor>

    <!-- IMU -->
    <sensor name="d435i_imu" type="imu">
      <always_on>true</always_on>
      <update_rate>200</update_rate>

      <plugin name="d435i_imu_controller" filename="libgazebo_ros_imu_sensor.so">
        <ros>
          <namespace>/d435i/imu</namespace>
        </ros>
        <frame_name>camera_d435i_imu_frame</frame_name>
        <topic_name>/d435i/imu/data_raw</topic_name>
        <gaussian_noise>0.0005</gaussian_noise>
      </plugin>
    </sensor>

  </gazebo>
 
  <!-- ============================= -->
  <!-- 3. Cameras Fisheyes (4 on Top) -->
  <!-- ============================= -->

  <!-- Camera Fisheye Front -->
  <joint name="camera_fisheye_front_joint" type="fixed">
    <parent link="base_link"/>
    <child link="camera_fisheye_front_link"/>
    <origin xyz="0.07 0 1.845" rpy="0 0.628 -0.0255"/>
  </joint>

  <link name="camera_fisheye_front_link">
    <visual name="fisheye_front">
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <sphere radius="0.00346"/>
      </geometry>
    </visual>

    <inertial>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <mass value="0.01"/>
      <inertia ixx="1e-06" ixy="0" ixz="0" 
               iyy="1e-06" iyz="0" 
               izz="1e-06" />
    </inertial>
  </link>

  <!-- Camera Fisheye Front Optical Frame -->
  <link name="camera_fisheye_front_optical_frame"/>
  <joint name="camera_fisheye_front_optical_joint" type="fixed">
    <parent link="camera_fisheye_front_link"/>
    <child link="camera_fisheye_front_optical_frame"/>
    <origin xyz="0 0 0" rpy="-1.5708 0 -1.5708"/> <!-- rotate to optical frame -->
  </joint>

  <!--Camera Fisheye Left-->
  <joint name="camera_fisheye_left_joint" type="fixed">
      <origin xyz="-0.2 0.18 1.845" rpy="0 0.628 1.5708"/>
      <parent link="base_link"/>
      <child link="camera_fisheye_left_link"/>
  </joint>

  <link name="camera_fisheye_left_link">
    <visual name="fisheye_left">
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
         <sphere radius="0.00346"/>
      </geometry>
    </visual>

    <inertial>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <mass value="0.01"/>
      <inertia ixx="1e-06" ixy="0" ixz="0" 
               iyy="1e-06" iyz="0" 
               izz="1e-06" />
    </inertial>
  </link>

  <!-- Camera Fisheye Left Optical Frame -->
  <link name="camera_fisheye_left_optical_frame"/>
  <joint name="camera_fisheye_left_optical_joint" type="fixed">
    <parent link="camera_fisheye_left_link"/>
    <child link="camera_fisheye_left_optical_frame"/>
    <origin xyz="0 0 0" rpy="-1.5708 0 -1.5708"/> <!-- rotate to optical frame -->
  </joint>

  <!-- Camera Fisheye Right -->
  <joint name="camera_fisheye_right_joint" type="fixed">
      <origin xyz="-0.2 -0.18 1.845" rpy="0 0.628 -1.5708"/>
      <parent link="base_link"/>
      <child link="camera_fisheye_right_link"/>
  </joint>

  <link name="camera_fisheye_right_link">
    <visual name="fisheye_right">
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <sphere radius="0.00346"/>
      </geometry>
    </visual>

    <inertial>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <mass value="0.01"/>
      <inertia ixx="1e-06" ixy="0" ixz="0" 
               iyy="1e-06" iyz="0" 
               izz="1e-06" />
    </inertial>
  </link>

  <!-- Camera Fisheye Right Optical Frame -->
  <link name="camera_fisheye_right_optical_frame"/>
  <joint name="camera_fisheye_right_optical_joint" type="fixed">
    <parent link="camera_fisheye_right_link"/>
    <child link="camera_fisheye_right_optical_frame"/>
    <origin xyz="0 0 0" rpy="-1.5708 0 -1.5708"/> <!-- rotate to optical frame -->
  </joint>

  <!-- Camera Fisheye Rear -->
  <joint name="camera_fisheye_rear_joint" type="fixed">
    <parent link="base_link"/>
    <child link="camera_fisheye_rear_link"/>
    <origin xyz="-0.5 0 1.845" rpy="3.1416 2.513274 0"/>
  </joint>

  <link name="camera_fisheye_rear_link">
    <visual name="fisheye_rear">
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <sphere radius="0.00346"/>
      </geometry>
    </visual>

    <inertial>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <mass value="0.01"/>
      <inertia ixx="1e-06" ixy="0" ixz="0" 
               iyy="1e-06" iyz="0" 
               izz="1e-06" />
    </inertial>
  </link>

  <!-- Camera Fisheye Rear Optical Frame -->
  <link name="camera_fisheye_rear_optical_frame"/>
  <joint name="camera_fisheye_rear_optical_joint" type="fixed">
    <parent link="camera_fisheye_rear_link"/>
    <child link="camera_fisheye_rear_optical_frame"/>
    <origin xyz="0 0 0" rpy="-1.5708 0 -1.5708"/> <!-- rotate to optical frame -->
  </joint>

  <!-- ============================= -->
  <!-- 3. Gazebo plugins for Cameras Fisheyes (4 on Top) -->
  <!-- ============================= -->
  <!-- Camera Fisheye Front -->
  <gazebo reference="camera_fisheye_front_link">
    <sensor name="fisheye_front" type="wideanglecamera">
      <pose>0 0 0 0 0 0</pose>
      <always_on>true</always_on>
      <update_rate>60</update_rate>

      <camera>
        <horizontal_fov>2.967</horizontal_fov> <!-- 170 deg -->
        <image>
          <width>640</width>
          <height>480</height>
          <format>R8G8B8</format>
        </image>
        <clip>
          <near>0.05</near>
          <far>20.0</far>
        </clip>
        <lens>
          <type>custom</type>
          <custom_function>
            <c1>1.05</c1>
            <c2>4</c2>
            <f>1.0</f>
            <fun>tan</fun>
          </custom_function>
          <scale_to_hfov>true</scale_to_hfov>
          <cutoff_angle>2.967</cutoff_angle>
        </lens>
      </camera>

      <plugin name="fisheye_front_controller" filename="libgazebo_ros_camera.so">
        <ros>
          <namespace>/fisheye/front</namespace>
        </ros>
        <frame_name>camera_fisheye_front_optical_frame</frame_name>
        <image_topic_name>/fisheye/front/image_raw</image_topic_name>
        <camera_info_topic_name>/fisheye/front/camera_info</camera_info_topic_name>
        <always_on>true</always_on>
        <update_rate>60</update_rate>
      </plugin>
    </sensor>
  </gazebo>

  <!-- Camera Fisheye Left-->
  <gazebo reference="camera_fisheye_left_link">
    <sensor name="fisheye_left" type="wideanglecamera">
      <pose>0 0 0 0 0 0</pose>
      <always_on>true</always_on>
      <update_rate>60</update_rate>

      <camera>
        <horizontal_fov>2.967</horizontal_fov>
        <image>
          <width>640</width>
          <height>480</height>
          <format>R8G8B8</format>
        </image>
        <clip>
          <near>0.05</near>
          <far>20.0</far>
        </clip>
        <lens>
          <type>custom</type>
          <custom_function>
            <c1>1.05</c1>
            <c2>4</c2>
            <f>1.0</f>
            <fun>tan</fun>
          </custom_function>
          <scale_to_hfov>true</scale_to_hfov>
          <cutoff_angle>2.967</cutoff_angle>
        </lens>
      </camera>

      <plugin name="fisheye_left_controller" filename="libgazebo_ros_camera.so">
        <ros>
          <namespace>/fisheye/left</namespace>
        </ros>
        <frame_name>camera_fisheye_left_optical_frame</frame_name>
        <image_topic_name>/fisheye/left/image_raw</image_topic_name>
        <camera_info_topic_name>/fisheye/left/camera_info</camera_info_topic_name>
        <always_on>true</always_on>
        <update_rate>60</update_rate>
      </plugin>
    </sensor>
  </gazebo>

  <!-- Camera Fisheye Right -->
  <gazebo reference="camera_fisheye_right_link">
    <sensor name="fisheye_right" type="wideanglecamera">
      <pose>0 0 0 0 0 0</pose>
      <always_on>true</always_on>
      <update_rate>60</update_rate>

      <camera>
        <horizontal_fov>2.967</horizontal_fov>
        <image>
          <width>640</width>
          <height>480</height>
          <format>R8G8B8</format>
        </image>
        <clip>
          <near>0.05</near>
          <far>20.0</far>
        </clip>
        <lens>
          <type>custom</type>
          <custom_function>
            <c1>1.05</c1>
            <c2>4</c2>
            <f>1.0</f>
            <fun>tan</fun>
          </custom_function>
          <scale_to_hfov>true</scale_to_hfov>
          <cutoff_angle>2.967</cutoff_angle>
        </lens>
      </camera>

      <plugin name="fisheye_right_controller" filename="libgazebo_ros_camera.so">
        <ros>
          <namespace>/fisheye/right</namespace>
        </ros>
        <frame_name>camera_fisheye_right_optical_frame</frame_name>
        <image_topic_name>/fisheye/right/image_raw</image_topic_name>
        <camera_info_topic_name>/fisheye/right/camera_info</camera_info_topic_name>
        <always_on>true</always_on>
        <update_rate>60</update_rate>
      </plugin>
    </sensor>
  </gazebo>

  <!-- Camera Fisheye Rear -->
  <gazebo reference="camera_fisheye_rear_link">
    <sensor name="fisheye_rear" type="wideanglecamera">
      <pose>0 0 0 0 0 0</pose>
      <always_on>true</always_on>
      <update_rate>60</update_rate>

      <camera>
        <horizontal_fov>2.967</horizontal_fov>
        <image>
          <width>640</width>
          <height>480</height>
          <format>R8G8B8</format>
        </image>
        <clip>
          <near>0.05</near>
          <far>20.0</far>
        </clip>
        <lens>
          <type>custom</type>
          <custom_function>
            <c1>1.05</c1>
            <c2>4</c2>
            <f>1.0</f>
            <fun>tan</fun>
          </custom_function>
          <scale_to_hfov>true</scale_to_hfov>
          <cutoff_angle>2.967</cutoff_angle>
        </lens>
      </camera>
      
      <plugin name="fisheye_rear_controller" filename="libgazebo_ros_camera.so">
        <ros>
          <namespace>/fisheye/rear</namespace>
        </ros>
        <frame_name>camera_fisheye_rear_optical_frame</frame_name>
        <image_topic_name>/fisheye/rear/image_raw</image_topic_name>
        <camera_info_topic_name>/fisheye/rear/camera_info</camera_info_topic_name>
        <always_on>true</always_on>
        <update_rate>60</update_rate>
      </plugin>
    </sensor>
  </gazebo>
  
  <!-- ============================= -->
  <!-- 4. Ultrasonic Sensors (5 on Base)-->
  <!-- ============================= -->
  
  <!-- Ultrasonic Front Left  -->
    <joint name="ultrasonic_front_left_joint" type="fixed">
    <origin xyz="0.08 -0.1293 0.2115" rpy="0 0 0"/>
    <parent link="base_link"/>
    <child link="ultrasonic_front_left_link"/>
  </joint>

  <link name="ultrasonic_front_left_link">
    <visual name="front_left_sonar">
      <origin xyz="0 0 0" rpy="0 0 0"/> <!-- no rotation -->
      <geometry>
        <sphere radius="0.00346"/>
      </geometry>
    </visual>

    <inertial>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <mass value="0.01"/>
      <inertia ixx="1e-06" ixy="0" ixz="0" 
              iyy="1e-06" iyz="0" 
              izz="1e-06" />
    </inertial>
  </link>

  <!-- Ultrasonic Front Right -->
  <joint name="ultrasonic_front_right_joint" type="fixed">
    <origin xyz="0.08 0.1337 0.21166" rpy="0 0 0"/>
    <parent link="base_link"/>
    <child link="ultrasonic_front_right_link"/>
  </joint>

  <link name="ultrasonic_front_right_link">
    <visual name="front_right_sonar">
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <sphere radius="0.00346"/>
      </geometry>
    </visual>

    <inertial>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <mass value="0.01"/>
      <inertia ixx="1e-06" ixy="0" ixz="0" 
               iyy="1e-06" iyz="0" 
               izz="1e-06" />
    </inertial>
  </link>

  <!-- Ultrasonic Side Left -->
  <joint name="ultrasonic_side_left_joint" type="fixed">
    <parent link="base_link"/>
    <child link="ultrasonic_side_left_link"/>
    <origin xyz="-0.34701 -0.215 0.21154" rpy="0 0 -1.5708"/>
  </joint>

  <link name="ultrasonic_side_left_link">
    <visual name="side_left_sonar">
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <sphere radius="0.00346"/>
      </geometry>
    </visual>

    <inertial>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <mass value="0.01"/>
      <inertia ixx="1e-06" ixy="0" ixz="0" 
               iyy="1e-06" iyz="0" 
               izz="1e-06" />
    </inertial>
  </link>

  <!-- Ultrasonic Side Right -->
  <joint name="ultrasonic_side_right_joint" type="fixed">
    <origin xyz="-0.34701 0.215 0.21154" rpy="0 0 1.5708"/>
    <parent link="base_link"/>
    <child link="ultrasonic_side_right_link"/>
  </joint>

  <link name="ultrasonic_side_right_link">
    <visual name="side_right_sonar">
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <sphere radius="0.00346"/>
      </geometry>
    </visual>

    <inertial>
        <origin xyz="0 0 0" rpy="0 0 0"/>
        <mass value="0.01"/>
        <inertia ixx="1e-06" ixy="0" ixz="0" 
                 iyy="1e-06" iyz="0" 
                 izz="1e-06" />
     </inertial>
    </link>

  <!-- Ultrasonic Rear  -->
  <joint name="ultrasonic_rear_joint" type="fixed">
      <origin xyz="-0.562 0.01302 0.33103" rpy="0 0 3.14159"/>
      <parent link="base_link"/>
      <child link="ultrasonic_rear_link"/>
  </joint>

  <link name="ultrasonic_rear_link">
    <visual name="rear_sonar">
        <origin xyz="0 0 0" rpy="0 0 0"/>
        <geometry>
          <sphere radius="0.00346"/>
        </geometry>
    </visual>

    <inertial>
        <origin xyz="0 0 0" rpy="0 0 0"/>
        <mass value="0.01"/>
        <inertia ixx="1e-06" ixy="0" ixz="0" 
                 iyy="1e-06" iyz="0" 
                 izz="1e-06" />
    </inertial>
  </link>

  <!-- ============================= -->
  <!-- 4. Gazebo plugins for Ultrasonic Sensors -->
  <!-- ============================= -->

  <!-- Front Left -->
  <gazebo reference="ultrasonic_front_left_link">
    <sensor name="ultrasonic_front_left" type="ray">
      <always_on>true</always_on>
      <visualize>true</visualize>
      <update_rate>5</update_rate>

      <ray>
        <scan>
           <horizontal><samples>5</samples><resolution>1</resolution><min_angle>-0.25</min_angle><max_angle>0.25</max_angle></horizontal>
           <vertical><samples>5</samples><resolution>1</resolution><min_angle>-0.25</min_angle><max_angle>0.25</max_angle></vertical>
        </scan>
        <range><min>0.01</min><max>0.75</max><resolution>0.01</resolution></range>
      </ray>

      <plugin name="ultrasonic_front_left_controller" filename="libgazebo_ros_ray_sensor.so">
        <ros><namespace>/ultrasound/front_left</namespace></ros>
        <frame_name>ultrasonic_front_left_link</frame_name>
        <output_type>sensor_msgs/Range</output_type>
        <gaussianNoise>0.005</gaussianNoise>
      </plugin>
    </sensor>
  
  </gazebo>

  <!-- Front Right -->
  <gazebo reference="ultrasonic_front_right_link">
    <sensor name="ultrasonic_front_right" type="ray">
      <always_on>true</always_on>
      <visualize>true</visualize>
      <update_rate>5</update_rate>

      <ray>
        <scan>
           <horizontal><samples>5</samples><resolution>1</resolution><min_angle>-0.25</min_angle><max_angle>0.25</max_angle></horizontal>
           <vertical><samples>5</samples><resolution>1</resolution><min_angle>-0.25</min_angle><max_angle>0.25</max_angle></vertical>
        </scan>
        <range><min>0.01</min><max>0.75</max><resolution>0.01</resolution></range>
      </ray>

      <plugin name="ultrasonic_front_right_controller" filename="libgazebo_ros_ray_sensor.so">
        <ros><namespace>/ultrasound/front_right</namespace></ros>
        <frame_name>ultrasonic_front_right_link</frame_name>
        <output_type>sensor_msgs/Range</output_type>
        <gaussianNoise>0.005</gaussianNoise>
      </plugin>
    </sensor>
  
  </gazebo>

  <!-- Rear -->
  <gazebo reference="ultrasonic_rear_link">
    <sensor name="ultrasonic_rear" type="ray">
      <always_on>true</always_on>
      <visualize>true</visualize>
      <update_rate>5</update_rate>

      <ray>
        <scan>
          <horizontal><samples>5</samples><resolution>1</resolution><min_angle>-0.25</min_angle><max_angle>0.25</max_angle></horizontal>
          <vertical><samples>5</samples><resolution>1</resolution><min_angle>-0.25</min_angle><max_angle>0.25</max_angle></vertical>
        </scan>
        <range><min>0.01</min><max>0.75</max><resolution>0.01</resolution></range>
      </ray>

      <plugin name="ultrasonic_rear_controller" filename="libgazebo_ros_ray_sensor.so">
        <ros><namespace>/ultrasound/rear</namespace></ros>
        <frame_name>ultrasonic_rear_link</frame_name>
        <output_type>sensor_msgs/Range</output_type>
        <gaussianNoise>0.005</gaussianNoise>
      </plugin>
    </sensor>

  </gazebo>

  <!-- Side Left -->
  <gazebo reference="ultrasonic_side_left_link">
    <sensor name="ultrasonic_side_left" type="ray">
      <always_on>true</always_on>
      <visualize>true</visualize>
      <update_rate>5</update_rate>

      <ray>
        <scan>
          <horizontal><samples>5</samples><resolution>1</resolution><min_angle>-0.25</min_angle><max_angle>0.25</max_angle></horizontal>
          <vertical><samples>5</samples><resolution>1</resolution><min_angle>-0.25</min_angle><max_angle>0.25</max_angle></vertical>
        </scan>
        <range><min>0.01</min><max>0.75</max><resolution>0.01</resolution></range>
      </ray>

      <plugin name="ultrasonic_side_left_controller" filename="libgazebo_ros_ray_sensor.so">
        <ros><namespace>/ultrasound/left</namespace></ros>
        <frame_name>ultrasonic_side_left_link</frame_name>
        <output_type>sensor_msgs/Range</output_type>
        <gaussianNoise>0.005</gaussianNoise>
      </plugin>
    </sensor>
  </gazebo>

  <!-- Side Right -->
  <gazebo reference="ultrasonic_side_right_link">
    <sensor name="ultrasonic_side_right" type="ray">
      <always_on>true</always_on>
      <visualize>true</visualize>
      <update_rate>5</update_rate>

      <ray>
        <scan>
          <horizontal><samples>5</samples><resolution>1</resolution><min_angle>-0.25</min_angle><max_angle>0.25</max_angle></horizontal>
          <vertical><samples>5</samples><resolution>1</resolution><min_angle>-0.25</min_angle><max_angle>0.25</max_angle></vertical>
        </scan>
        <range><min>0.01</min><max>0.75</max><resolution>0.01</resolution></range>
      </ray>

      <plugin name="ultrasonic_side_right_controller" filename="libgazebo_ros_ray_sensor.so">
        <ros><namespace>/ultrasound/right</namespace></ros>
        <frame_name>ultrasonic_side_right_link</frame_name>
        <output_type>sensor_msgs/Range</output_type>
        <gaussianNoise>0.005</gaussianNoise>
      </plugin>
    </sensor>
  </gazebo>

  <!-- ============================= -->
  <!--UVC Lights (6 on Base)-->
  <!-- ============================= -->

  <joint name="uvc_lights_joint" type="fixed">
    <parent link="base_link"/>
    <child link="uvc_lights_link"/>
    <origin xyz="-0.3361 0 0.52606" rpy="0 0 0"/>
  </joint>

  <link name="uvc_lights_link">
    <visual name="light_1">
      <origin xyz="-0.10432 -0.07221 0.64035" rpy="0 0 0"/>
      <geometry>
        <cylinder radius="0.01004" length="1.32715"/>
      </geometry>
      <material name="blue"/>
    </visual>

    <visual name="light_2">
      <origin xyz="-0.10432 0.07284 0.64035" rpy="0 0 0"/>
      <geometry>
        <cylinder radius="0.01004" length="1.32715"/>
      </geometry>
      <material name="blue"/>
    </visual>

    <visual name="light_3">
      <origin xyz="0.0941 0.1377 0.64035" rpy="0 0 0"/>
      <geometry>
        <cylinder radius="0.01004" length="1.32715"/>
      </geometry>
      <material name="blue"/>
    </visual>

    <visual name="light_4">
      <origin xyz="-0.02265 0.1377 0.64035" rpy="0 0 0"/>
      <geometry>
        <cylinder radius="0.01004" length="1.32715"/>
      </geometry>
      <material name="blue"/>
    </visual>

    <visual name="light_5">
      <origin xyz="0.0941 -0.14053 0.64035" rpy="0 0 0"/>
      <geometry>
        <cylinder radius="0.01004" length="1.32715"/>
      </geometry>
      <material name="blue"/>
    </visual>

    <visual name="light_6">
      <origin xyz="-0.02265 -0.14053 0.64035" rpy="0 0 0"/>
      <geometry>
        <cylinder radius="0.01004" length="1.32715"/>
      </geometry>
      <material name="blue"/>
    </visual>

    <inertial>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <mass value="0.9"/>
      <inertia ixx="1.44e-04" ixy="0" ixz="0"
              iyy="1.44e-04" iyz="0"
              izz="7.2e-04"/>
    </inertial>
  </link>

  <!-- ============================= -->
  <!-- DIFFERENTIAL DRIVE -->
  <!-- ============================= -->
  <gazebo>
    <plugin name="uvc1_diff_drive" filename="libgazebo_ros_diff_drive.so">
      <ros>
        <namespace>/</namespace>
      </ros>
      <!-- wheels-->
      <left_joint>wheel_front_left_joint</left_joint>
      <right_joint>wheel_front_right_joint</right_joint>
      <!--kinematics-->
      <wheel_separation>0.356</wheel_separation>
      <wheel_diameter>0.165</wheel_diameter>
      <!--control limits-->
      <max_wheel_torque>20</max_wheel_torque>
      <update_rate>100</update_rate>

      <command_topic>cmd_vel</command_topic>
      <!--odometry outputs-->
      <publish_odom>true</publish_odom>
      <publish_odom_tf>true</publish_odom_tf>
      <odometry_topic>odom</odometry_topic>
      <robot_base_frame>base_footprint</robot_base_frame>
    </plugin>

    <!-- ============================= -->
    <!-- JOINT STATE PUBLISHER -->
    <!-- ============================= -->

    <plugin name="uvc1_joint_state"
        filename="libgazebo_ros_joint_state_publisher.so">

      <ros>
        <remapping>~/out:=joint_states</remapping>
      </ros>

      <update_rate>30</update_rate>

      <joint_name>wheel_front_left_joint</joint_name>
      <joint_name>wheel_front_right_joint</joint_name>

      <joint_name>wrist_rear_left_joint</joint_name>
      <joint_name>wheel_rear_left_joint</joint_name>

      <joint_name>wrist_rear_right_joint</joint_name>
      <joint_name>wheel_rear_right_joint</joint_name>

    </plugin>
  </gazebo>

</robot>